{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "laravel/framework": "^13.0",
        "league/csv": "^9.0",
        "guzzlehttp/guzzle": "^7.0",
        "doctrine/dbal": "^3.0",
        "predis/predis": "^3.0",
        "yajra/laravel-datatables-oracle": "^13.0",
        "propaganistas/laravel-phone": "^6.0",
        "laravel/socialite": "^5.0",
        "kalnoy/nestedset": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Quarx\\": "quarx/"
        },
        "files": [
            "app/auth-helpers.php",
            "app/email-helpers.php",
            "app/file-helpers.php",
            "app/transformer-helpers.php",
            "app/view-helpers.php"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "php -r \"copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "github-oauth": {
            "github.com": "dd31c35f932d560608daf0db6b5027a3f2ca741a"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
